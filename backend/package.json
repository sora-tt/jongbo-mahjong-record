{
  "name": "hono",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app/server.ts",
    "start": "tsx src/app/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.{ts,tsx,js,mjs,cjs}'",
    "lint:fix": "eslint 'src/**/*.{ts,tsx,js,mjs,cjs}' --fix",
    "emulator": "NODE_NO_WARNINGS=1 firebase emulators:start --project jongbo-local",
    "dev:emulator": "USE_FIRESTORE_EMULATOR=true FIRESTORE_EMULATOR_HOST=127.0.0.1:8081 FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099 GOOGLE_CLOUD_PROJECT=jongbo-local tsx watch src/app/server.ts",
    "seed": "USE_FIRESTORE_EMULATOR=true FIRESTORE_EMULATOR_HOST=127.0.0.1:8081 FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099 GOOGLE_CLOUD_PROJECT=jongbo-local tsx src/scripts/seedFirestore.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.4",
    "@hono/swagger-ui": "^0.6.1",
    "firebase-admin": "^13.4.0",
    "hono": "^4.12.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^20.11.17",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "firebase-tools": "^14.22.0",
    "prettier": "^3.3.3",
    "tsx": "^4.7.1",
    "typescript-eslint": "^8.46.1",
    "typescript": "^5.8.3"
  }
}
